<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hapticaudio">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="HapticAudio 控制台"
        android:theme="@android:style/Theme.Material.Light.DarkActionBar">
        
        <meta-data android:name="xposedmodule" android:value="true" />
        <meta-data android:name="xposeddescription" android:value="全自研音频转线性马达驱动引擎，支持参数微调与物理级静音。" />
        <meta-data android:name="xposedminversion" android:value="93" />

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <receiver android:name=".StatusReceiver" android:exported="true">
            <intent-filter>
                <action android:name="com.hapticaudio.STATUS_UPDATE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
